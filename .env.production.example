APP_NAME=MediTrack
APP_ENV=production
APP_KEY=                          # Generate dengan: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://domainanda.com    # Ganti dengan domain Jago Hosting Anda

APP_LOCALE=id
APP_FALLBACK_LOCALE=id

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nama_database         # Ganti sesuai database di cPanel
DB_USERNAME=nama_user_db          # Ganti sesuai user di cPanel
DB_PASSWORD=password_db           # Ganti dengan password database

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@domainanda.com"
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=domainanda.com    # Ganti dengan domain Anda
